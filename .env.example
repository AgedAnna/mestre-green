# ─── Mestre Green Web — environment template ───────────────────────────────────
# Copy to .env.local and fill in. .env.local is gitignored.

# NextAuth session secret (required). Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Backend base URL used by SERVER code (lib/api.ts). Defaults to the production
# API when unset. Override during local backend development.
# API_BASE=http://localhost:8080

# Backend base URL used by the BROWSER realtime client (lib/realtime.ts).
# Must be public (NEXT_PUBLIC_). Defaults to the production API.
NEXT_PUBLIC_API_BASE=https://api.mestregreen.com

# Existing Google "Web" client ID (public) for the "Sign in with Google" button.
# Same id the backend already validates (GOOGLE_CLIENT_IDS) — reuse, not new setup.
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional dev-only NextAuth helpers (leave off in production):
# AUTH_URL=http://localhost:3000
# AUTH_TRUST_HOST=true
